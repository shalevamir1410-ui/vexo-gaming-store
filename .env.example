# VEXO Gaming Store - Environment Variables
# Copy this file to .env and fill in your actual values for local development
# For cloud deployment (Render/Railway), set these in the platform's environment variables panel

# Server Configuration
PORT=3000
NODE_ENV=development

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CJ Dropshipping API
# Get your API key from: https://cjdropshipping.com/account/api
CJ_API_KEY=CJ5295285@api@e27a42bec7174b39b21e18c5f610e136

# Database Configuration
# For SQLite (default - local development)
DATABASE_URL=./database.sqlite

# For cloud database (Render PostgreSQL or Railway MySQL), uncomment and modify:
# DATABASE_URL=postgresql://user:password@host:port/database
# Or use individual variables:
# DB_HOST=your-db-host
# DB_PORT=5432
# DB_NAME=vexo_store
# DB_USER=your-db-user
# DB_PASSWORD=your-db-password

# Optional: Admin Email (for admin access)
ADMIN_EMAIL=Shalevamir1410@gmail.com

# Optional: Server URL (for production)
# SERVER_URL=https://your-app-name.onrender.com
